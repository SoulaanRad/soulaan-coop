// ── SC Reward Tracking Models ────────────────────────────

model SCRewardTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  coopId String

  // Reward details
  amountSC Float
  reason   SCRewardReason
  status   SCRewardStatus @default(PENDING)

  // Blockchain
  txHash String? @unique

  // Source UC transaction tracking (ties SC mint to originating treasury transaction)
  sourceUcTxHash String? // UC payment tx that triggered this SC reward
  sourceType     String? // 'STORE_ORDER' | 'P2P_TRANSFER' | 'MANUAL' | null
  sourceRecordId String? // ID of source record (StoreOrder.id or P2PTransfer.id)

  // Context - link to store purchase
  relatedStoreId String?
  relatedStore   Store?      @relation(fields: [relatedStoreId], references: [id])
  relatedOrderId String?
  relatedOrder   StoreOrder? @relation(fields: [relatedOrderId], references: [id])

  // On-chain event metadata (for trustless system auditability)
  metadata Json?

  // Timestamps
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  failedAt    DateTime?

  // Error tracking for retries
  failureReason String?
  retryCount    Int       @default(0)
  lastRetryAt   DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([coopId])
  @@index([status])
  @@index([relatedStoreId])
  @@index([relatedOrderId])
  @@index([sourceUcTxHash])
  @@index([sourceRecordId])
  @@schema("public")
}

enum SCRewardReason {
  STORE_PURCHASE_REWARD // Customer reward for shopping
  STORE_SALE_REWARD // Store owner reward for sale
  MANUAL_ADJUSTMENT // Admin manual grant/adjustment

  @@schema("public")
}

enum SCRewardStatus {
  PENDING
  COMPLETED
  FAILED

  @@schema("public")
}

// ── Treasury Reserve Tracking Models ────────────────────────────

model TreasuryReservePolicy {
  id     String @id @default(cuid())
  coopId String

  // Default reserve rate in basis points (500 = 5%)
  defaultReserveBps Int @default(500)

  // Optional overrides for special programs
  badgeReserveBps   Int? // Override for badge-linked transactions
  programReserveBps Json? // { "program_key": bps_value } for special programs

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String // wallet address

  @@index([coopId, isActive])
  @@schema("public")
}

model TreasuryReserveEntry {
  id     String @id @default(cuid())
  coopId String

  // Source transaction linkage
  sourceType     String // 'STORE_ORDER' | 'P2P_TRANSFER' | 'MANUAL'
  sourceRecordId String // StoreOrder.id or P2PTransfer.id
  sourceUcTxHash String // Original UC payment transaction

  // Reserve calculation
  transactionAmountUC Float // Original transaction amount in UC
  reservePercentBps   Int // Reserve rate used (basis points)
  reserveAmountUC     Float // Calculated reserve amount

  // Treasury settlement
  treasuryTxHash String?               @unique // On-chain transfer to treasury
  status         TreasuryReserveStatus @default(PENDING)

  // Linkage to SC rewards created from this transaction
  relatedScRewardIds String[] // Array of SCRewardTransaction IDs

  // Timestamps
  createdAt     DateTime  @default(now())
  settledAt     DateTime?
  failedAt      DateTime?
  failureReason String?
  retryCount    Int       @default(0)

  @@index([coopId])
  @@index([sourceUcTxHash])
  @@index([sourceRecordId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@schema("public")
}

enum TreasuryReserveStatus {
  PENDING // Reserve calculated, transfer not yet attempted
  SETTLING // Transfer in progress
  SETTLED // Successfully transferred to treasury
  FAILED // Transfer failed

  @@schema("public")
}

// WealthFundAddressChange model removed - now tracked on-chain via contract events
// See UnityCoin.sol PrivilegedAddressChanged event

// ── Hybrid Architecture Models ────────────────────────────

// ── Wallet Management ──────────────────────────────────────

model Wallet {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  address    String     @unique
  chain      String     @default("base-sepolia") // base-sepolia, base-mainnet, ethereum, etc.
  walletType WalletType
  isPrimary  Boolean    @default(false)

  // Managed wallet custody (only for walletType = MANAGED)
  encryptedPrivateKey String? // Encrypted private key for backend-managed wallets
  custodyProvider     String? // 'backend' | future: 'fireblocks', 'aws-kms'

  // Verification
  verifiedAt DateTime?
  lastSeenAt DateTime?

  // SC balance cache
  scBalanceCache SCBalanceCache?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isPrimary])
  @@index([address])
  @@schema("public")
}

enum WalletType {
  EXTERNAL // User-controlled wallet (MetaMask, Coinbase Wallet, etc.)
  MANAGED // Backend-managed wallet with encrypted key

  @@schema("public")
}

// ── Stripe Connect & Business Onboarding ──────────────────

model StripeAccount {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  stripeAccountId String @unique
  accountType     String // 'standard' | 'express' | 'custom'
  country         String @default("US")

  // Capability state
  chargesEnabled   Boolean @default(false)
  payoutsEnabled   Boolean @default(false)
  detailsSubmitted Boolean @default(false)

  // Requirements tracking
  requirementsCurrentlyDue  String[] // ['individual.first_name', 'business.tax_id', ...]
  requirementsEventuallyDue String[]
  requirementsPastDue       String[]

  // Verification status
  verificationStatus StripeVerificationStatus @default(UNVERIFIED)

  // Onboarding status (internal tracking)
  onboardingStatus StripeOnboardingStatus @default(DRAFT)

  // Future: card issuing eligibility (not implemented yet)
  cardIssuingEligible Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeAccountId])
  @@index([onboardingStatus])
  @@schema("public")
}

enum StripeVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED

  @@schema("public")
}

enum StripeOnboardingStatus {
  DRAFT // Account created, not yet submitted
  SUBMITTED // Onboarding info submitted
  RESTRICTED // Account restricted, needs more info
  CHARGES_ENABLED // Can accept charges
  PAYOUTS_ENABLED // Can receive payouts
  REJECTED // Verification rejected

  @@schema("public")
}

model BusinessOnboardingEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  status     StripeOnboardingStatus
  metadata   Json? // Snapshot of requirements, capabilities, etc.
  occurredAt DateTime               @default(now())

  @@index([businessId, occurredAt(sort: Desc)])
  @@schema("public")
}

model SCVerificationApplication {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  whyScEligible  String
  expectedVolume String

  status          SCApplicationStatus @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@schema("public")
}

// ── Commerce Transactions (Stripe Payments) ───────────────

model CommerceTransaction {
  id String @id @default(cuid())

  // Parties
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  coopId     String

  // Pricing breakdown
  listedAmount             Float // Original item price
  chargedAmount            Float // Total charged to customer (includes platform markup)
  merchantSettlementAmount Float // Amount routed to merchant
  treasuryFeeAmount        Float // Platform/treasury fee retained
  currency                 String @default("USD")

  // Fee snapshot (captured at purchase time)
  platformMarkupBps Int? // Basis points used for this transaction
  treasuryFeeBps    Int? // Basis points used for this transaction

  // Stripe integration
  stripePaymentIntentId      String? @unique
  stripeChargeId             String?
  stripeDestinationAccountId String? // Connected account ID

  // Status
  status     CommerceTransactionStatus @default(PENDING)
  sourceType String                    @default("CHECKOUT") // CHECKOUT, QUICK_PAY, etc.

  // Metadata
  metadata Json? // Order details, line items, etc.

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Relations
  treasuryLedgerEntries TreasuryLedgerEntry[]
  scMintEvents          SCMintEvent[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([businessId, createdAt(sort: Desc)])
  @@index([coopId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@schema("public")
}

enum CommerceTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED

  @@schema("public")
}

// ── Stripe Webhook Events ─────────────────────────────────

model StripePaymentEvent {
  id String @id @default(cuid())

  stripeEventId String  @unique // Stripe event ID for idempotency
  eventType     String // 'payment_intent.succeeded', 'charge.refunded', etc.
  accountId     String? // Connected account ID if applicable

  payload     Json // Full Stripe event payload
  processed   Boolean   @default(false)
  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([stripeEventId])
  @@index([processed, createdAt])
  @@schema("public")
}

// ── Treasury Ledger (Fiat Accounting) ─────────────────────

model TreasuryLedgerEntry {
  id String @id @default(cuid())

  // Source linkage
  sourceTransactionId   String? // CommerceTransaction.id, ProposalId, etc.
  sourceTransactionType String // 'COMMERCE_FEE', 'REFUND', 'ALLOCATION', 'ADJUSTMENT'
  sourceTransaction     CommerceTransaction? @relation(fields: [sourceTransactionId], references: [id])

  // Accounting
  accountType TreasuryAccountType
  entryType   TreasuryEntryType
  amount      Float
  currency    String              @default("USD")
  direction   TreasuryDirection // CREDIT or DEBIT

  // Metadata
  description String?
  metadata    Json?

  occurredAt DateTime @default(now())

  @@index([accountType, occurredAt(sort: Desc)])
  @@index([sourceTransactionId])
  @@index([entryType])
  @@schema("public")
}

enum TreasuryAccountType {
  PLATFORM_FEES // Platform markup fees
  TREASURY_FEES // Community treasury fees
  PENDING_SETTLEMENT // Pending Stripe payouts
  ADJUSTMENTS // Manual adjustments
  GRANTS // Approved proposal allocations

  @@schema("public")
}

enum TreasuryEntryType {
  FEE_COLLECTION
  REFUND
  ALLOCATION
  ADJUSTMENT
  SETTLEMENT

  @@schema("public")
}

enum TreasuryDirection {
  CREDIT // Increases balance
  DEBIT // Decreases balance

  @@schema("public")
}

// ── Fee Configuration ──────────────────────────────────────

model FeeConfig {
  id String @id @default(cuid())

  // Fee structure (all in basis points, 100 bps = 1%)
  platformMarkupBps Int @default(400) // 4% platform markup
  merchantFeeBps    Int @default(0) // Merchant fee (future use)
  treasuryFeeBps    Int @default(400) // 4% treasury fee

  // Effective date range
  effectiveFrom DateTime
  effectiveTo   DateTime?

  isActive  Boolean  @default(true)
  createdBy String // Admin wallet/user ID
  createdAt DateTime @default(now())

  @@index([isActive, effectiveFrom])
  @@schema("public")
}

// ── SC Token Command/Event Tracking ───────────────────────

model SCMintEvent {
  id String @id @default(cuid())

  // Idempotency
  idempotencyKey String @unique

  // Target
  userId        String
  user          User   @relation(fields: [userId], references: [id])
  walletAddress String

  // Token details
  coopTokenClass  String // 'soulaan', 'sf-artist', etc.
  requestedAmount Float
  actualAmount    Float? // Actual amount minted (may differ due to contract rules)

  // Source linkage
  sourceTransactionId String?
  sourceTransaction   CommerceTransaction? @relation(fields: [sourceTransactionId], references: [id])
  sourceType          String? // 'COMMERCE_REWARD', 'MANUAL_GRANT', 'ONBOARDING', etc.

  // Blockchain
  contractTxHash String?       @unique
  blockNumber    Int?
  status         SCEventStatus @default(PENDING)

  // Metadata
  metadata Json?

  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([walletAddress])
  @@index([status])
  @@index([idempotencyKey])
  @@schema("public")
}

model SCBurnEvent {
  id String @id @default(cuid())

  // Idempotency
  idempotencyKey String @unique

  // Target
  userId        String
  user          User   @relation(fields: [userId], references: [id])
  walletAddress String

  // Token details
  requestedAmount Float
  actualAmount    Float?

  // Reason
  reason       String // 'VIOLATION', 'MANUAL_ADJUSTMENT', etc.
  authorizedBy String // Admin wallet/user ID

  // Blockchain
  contractTxHash String?       @unique
  blockNumber    Int?
  status         SCEventStatus @default(PENDING)

  // Metadata
  metadata Json?

  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([walletAddress])
  @@index([status])
  @@index([idempotencyKey])
  @@schema("public")
}

enum SCEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@schema("public")
}

// ── SC Balance Cache ───────────────────────────────────────

model SCBalanceCache {
  id       String @id @default(cuid())
  walletId String @unique
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  balance     Float
  blockNumber Int
  syncedAt    DateTime @default(now())

  @@index([walletId, syncedAt])
  @@schema("public")
}

// ── Feature Flags ──────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

// ── Admin Security (RBAC, MFA, Audit) ──────────────────────

model AdminRole {
  id        String        @id @default(cuid())
  userId    String
  coopId    String
  role      AdminRoleType
  grantedBy String // Admin user ID who granted the role
  grantedAt DateTime      @default(now())
  revokedAt DateTime?
  revokedBy String?

  @@unique([userId, coopId, role])
  @@index([userId])
  @@index([coopId])
  @@schema("public")
}

enum AdminRoleType {
  SUPER_ADMIN // Full system access
  TREASURY_ADMIN // Treasury allocation and fee config
  MERCHANT_ADMIN // Business onboarding approval
  TOKEN_ADMIN // SC mint/burn operations
  GOVERNANCE_ADMIN // Proposal moderation
  SUPPORT_ADMIN // Read-only support access

  @@schema("public")
}

model AuditLog {
  id String @id @default(cuid())

  // Actor
  actorId   String // User ID or system identifier
  actorType String // 'USER', 'ADMIN', 'SYSTEM'

  // Action
  action     String // 'SC_MINT', 'TREASURY_ALLOCATION', 'BUSINESS_APPROVAL', etc.
  resource   String // 'SCMintEvent', 'TreasuryLedgerEntry', 'Business', etc.
  resourceId String? // ID of affected resource

  // Context
  ipAddress String?
  userAgent String?
  metadata  Json?

  // Result
  status       AuditStatus
  errorMessage String?

  occurredAt DateTime @default(now())

  @@index([actorId, occurredAt(sort: Desc)])
  @@index([action, occurredAt(sort: Desc)])
  @@index([resource, resourceId])
  @@schema("public")
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING_APPROVAL

  @@schema("public")
}

// ══════════════════════════════════════════════════════════════
// PLATFORM CONFIG
// ══════════════════════════════════════════════════════════════

/**
 * Key/value store for platform-wide configuration.
 * Editable by admins. Cached at runtime.
 * Well-known keys:
 * coin.symbol      — e.g. "SC"
 * coin.name        — e.g. "Soulaan Coin"
 * coin.description — short description shown in UI
 * platform.name    — e.g. "Cahootz"
 */
model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String? // Admin user ID who last changed this

  @@schema("public")
}
