# API Server Configuration
# Copy this file to .env and fill in your values

# Server Port
PORT=3001

# Payment Processors (for webhooks)
# Get these from your payment processor dashboards

# Stripe (Primary payment processor)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Optional - Fallback payment processor)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...

# Square (Optional - Fallback payment processor)
SQUARE_WEBHOOK_SIGNATURE_KEY=...

# MinIO (S3-compatible object storage)
# Configure your MinIO instance endpoint and credentials
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Note: Additional environment variables are inherited from the root .env file:
# - OPENAI_API_KEY (for AI features)
# - DATABASE_URL (for database connection)
# - WALLET_ENCRYPTION_KEY (for wallet service)
# - RPC_URL (for blockchain interaction)
# - Per-coop contract addresses and initializer wallet address are stored in CoopConfig
