{
  "name": "soulaan-coop",
  "private": true,
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.11.1"
  },
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @repo/auth generate",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:migrate-prod": "turbo db:migrate-prod",
    "db:studio": "turbo db:studio",
    "db:push": "turbo db:push db:generate",
    "db:clear-blockchain": "tsx packages/db/migrations/clear-blockchain-data.ts",
    "db:seed-coops": "pnpm -F @repo/db seed:coop-display",
    "db:deploy-setup": "pnpm db:migrate-prod && pnpm db:seed-coops",
    "update-env": "bash scripts/update-all-env-files.sh",
    "update-contract-artifacts": "bash scripts/update-contract-artifacts.sh",
    "dev": "turbo watch dev --continue",
    "dev:api": "pnpm -F @soulaan-coop/api dev",
    "dev:web": "pnpm -F @soulaan-coop/web dev",
    "dev:next": "turbo watch dev -F @repo/nextjs...",
    "deploy:web": "pnpm db:deploy-setup && pnpm -F @soulaan-coop/web build",
    "format": "turbo run format --continue ",
    "format:fix": "turbo run format --continue ",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint --continue ",
    "lint:ws": "pnpm dlx sherif@latest -r unordered-dependencies",
    "postinstall": "pnpm lint:ws",
    "start": "turbo run start",
    "start:api": "pnpm -F @soulaan-coop/api start",
    "start:web": "pnpm -F @soulaan-coop/web start",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:contracts": "pnpm -F @soulaan/contracts test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "charter:validate": "node scripts/validate-charter-compliance.js",
    "setup:dev": "bash scripts/setup-dev.sh"
  },
  "devDependencies": {
    "@repo/prettier-config": "workspace:*",
    "@turbo/gen": "^2.6.3",
    "openai": "^6.10.0",
    "prettier": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "prettier": "@repo/prettier-config",
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-14505"
      ]
    },
    "overrides": {
    
      "effect": ">=3.20.0"
    }
  }
}
